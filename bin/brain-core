#!/usr/bin/env php
<?php

declare(strict_types=1);

use Illuminate\Console\Application;

/** @var Application $app */
$app = require __DIR__ . '/app.php';

$app->setName('Brain Core');

// Core commands
$app->add(new \BrainCore\Console\Commands\ConvertCommand());

$status = $app->run();

exit($status);
