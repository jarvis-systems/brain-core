{
    "name": "jarvis-brain/core",
    "description": "The Brain Core for Agent Management",
    "keywords": [
        "jarvis",
        "brain",
        "core"
    ],
    "type": "library",
    "version": "v0.4.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Xsaven",
            "email": "xsaven@gmail.com",
            "role": "Developer/Maintainer"
        }
    ],
    "autoload": {
        "psr-4": {
            "BrainCore\\": "src/"
        },
        "files": [
            "helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "BrainCore\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/brain-core",
        "bin/brain-script"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/config": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/bus": "^12.0",
        "illuminate/collections": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/encryption": "^12.0",
        "illuminate/filesystem": "^12.0",
        "illuminate/hashing": "^12.0",
        "illuminate/json-schema": "^12.0",
        "illuminate/macroable": "^12.0",
        "illuminate/log": "^12.0",
        "illuminate/pagination": "^12.0",
        "illuminate/process": "^12.0",
        "illuminate/redis": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/validation": "^12.0",
        "illuminate/view": "^12.0",
        "composer/composer": "^2.8",
        "yosymfony/toml": "^1.0",
        "bfg/dto": "^1.9",
        "symfony/var-exporter": "^7.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2.0",
        "symfony/var-dumper": "^7.3"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    }
}
